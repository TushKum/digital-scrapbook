# Copy to .env and adjust. The docker-compose Postgres uses these defaults.
DATABASE_URL="postgresql://neervana:neervana@localhost:5432/neervana?schema=public"

# API server
API_PORT=8787
CORS_ORIGIN=*
LOG_LEVEL=info
NODE_ENV=development

# Auth — CHANGE JWT_SECRET in production
JWT_SECRET=neervana-dev-secret-change-me
JWT_EXPIRES_IN=8h

# Default seeded operator (demo credentials)
SEED_OFFICER_USER=nodal.officer
SEED_OFFICER_PASSWORD=neervana@2026
SEED_OFFICER_NAME=District Nodal Officer
