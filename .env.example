# Copy to .env and adjust. The docker-compose Postgres uses these defaults.
# In production the host sets these — the Render Blueprint wires DATABASE_URL
# and JWT_SECRET automatically; you only set SEED_OFFICER_PASSWORD. See DEPLOY.md.
DATABASE_URL="postgresql://neervana:neervana@localhost:5432/neervana?schema=public"

# API server. Hosts inject PORT; locally the API uses API_PORT (default 8787).
API_PORT=8787
CORS_ORIGIN=*
LOG_LEVEL=info
NODE_ENV=development

# Serve the built dist/ SPA from the API process (single full-stack service).
# NODE_ENV=production enables this automatically; set true to test locally.
SERVE_WEB=false

# Auth — CHANGE JWT_SECRET in production (Render generates one automatically)
JWT_SECRET=neervana-dev-secret-change-me
JWT_EXPIRES_IN=8h

# Default seeded operator (demo credentials)
SEED_OFFICER_USER=nodal.officer
SEED_OFFICER_PASSWORD=neervana@2026
SEED_OFFICER_NAME=District Nodal Officer

# Frontend (build-time, Vite). Leave VITE_API_URL empty to call same-origin
# /api (correct for the single full-stack service). VITE_BASE is the public
# base path: "/" for root-served (default), "/repo/" only for a subpath host.
VITE_API_URL=
VITE_BASE=/
